@{
    ViewData["Title"] = "Tài khoản";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        height: 100vh;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Arial;
    }

    .navbar {
        background: #0d3b66;
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1000;
        transition: top 0.4s;

    }

        .navbar .nav-link {
            color: white;
            margin-right: 15px;
        }

    .card-auth {
        width: 420px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .tab-btn {
        width: 50%;
        border: none;
        padding: 10px;
        font-weight: bold;
    }

    .active-tab {
        background: #0d6efd;
        color: white;
    }

    .eye-btn {
        border: none;
        background: none;
        font-size: 18px;
    }

</style>
@if (ViewBag.ErrorRegister != null)
{
    <script>
        showRegister();
    </script>
}
<nav class="navbar navbar-expand-lg navbar-dark">

<div class="container">

    <a class="navbar-brand text-white">IVIVU</a>

    <div class="navbar-nav me-auto">
            <a href="~/Tour/Index" class=" nav-link text-white">Trang chủ</a>
    </div>

</div>

</nav>
    
<div class="card card-auth p-4">

    <h3 class="text-center mb-4">Tài khoản</h3>

    <div class="d-flex mb-4">

        <button id="loginTab" class="tab-btn active-tab" onclick="showLogin()">Đăng nhập</button>

        <button id="registerTab" class="tab-btn" onclick="showRegister()">Đăng ký</button>

    </div>

    <!-- LOGIN -->

    <div id="loginForm">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">
                @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">

            <input class="form-control mb-3"
                   name="Username"
                   placeholder="Tên tài khoản"
                   required>

            <div class="input-group mb-3">

                <input type="password"
                       id="loginPassword"
                       name="Password"
                       
                       class="form-control"            
                       placeholder="Mật khẩu"
                       required>

                <button type="button"
                        class="eye-btn"
                        onclick="togglePassword('loginPassword')">
                    👁
                </button>

            </div>

            <button class="btn btn-primary w-100">
                Đăng nhập
            </button>

        </form>

    </div>

    <!-- REGISTER -->

    <div id="registerForm" style="display:none">

        @if (ViewBag.ErrorRegister != null)
        {
            <div class="alert alert-danger text-center">
                @ViewBag.ErrorRegister
            </div>
        }

        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success text-center">
                @ViewBag.Success
            </div>
        }

        <form method="post" asp-action="Register" onsubmit="return checkPassword()">

            <input class="form-control mb-3"
                   name="Username"
                   placeholder="Tên tài khoản"
                   required>

            <input class="form-control mb-3"
                   name="Phone"
                   placeholder="Số điện thoại"
                   required>

            <div class="input-group mb-3">

                <input type="password"
                       id="password"
                       name="Password"
                       class="form-control"
                       placeholder="Mật khẩu (≥6 ký tự)"
                       minlength="6"
                       required>

                <button type="button"
                        class="eye-btn"
                        onclick="togglePassword('password')">
                    👁
                </button>

            </div>

            <div class="input-group mb-3">

                <input type="password"
                       id="confirmPassword"
                       class="form-control"
                       name="ConfirmPassword"
                       placeholder="Nhập lại mật khẩu"
                       required>

                <button type="button"
                        class="eye-btn"
                        onclick="togglePassword('confirmPassword')">
                    👁
                </button>

            </div>

            <button class="btn btn-success w-100">
                Đăng ký
            </button>

        </form>

    </div>

</div>

<script>
        window.onload = function () {

        var errorRegister = '@ViewBag.ErrorRegister';

    if (errorRegister && errorRegister !== "") {
        showRegister();
    }
    };
    function showLogin(){

    document.getElementById("loginForm").style.display="block";
    document.getElementById("registerForm").style.display="none";

    document.getElementById("loginTab").classList.add("active-tab");
    document.getElementById("registerTab").classList.remove("active-tab");

    }

    function showRegister(){

    document.getElementById("loginForm").style.display="none";
    document.getElementById("registerForm").style.display="block";

    document.getElementById("loginTab").classList.remove("active-tab");
    document.getElementById("registerTab").classList.add("active-tab");

    }

    function togglePassword(id){

    var x = document.getElementById(id);

    if(x.type === "password"){
    x.type = "text";
    }else{
    x.type = "password";
    }
    }
        function checkPassword(){

        var pass = document.getElementById("password").value;
        var confirm = document.getElementById("confirmPassword").value;

        if(pass !== confirm){
            alert("Mật khẩu nhập lại không đúng!");
            return false;
        }

        return true;
    }
    
        const images = [
    "/images/338596.jpg",
    "/images/1012111.jpg",
    "/images/238870.jpg",
    "/images/37864.jpg",
    "/images/476288.jpg",
    "/images/521718.jpg"
    ];

    const random = Math.floor(Math.random() * images.length);

    document.body.style.backgroundImage = "url('" + images[random] + "')";
</script>
