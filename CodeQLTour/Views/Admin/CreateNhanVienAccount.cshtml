@model CodeQLTour.Models.Account

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        height: 100vh;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Arial;
    }

    .card-auth {
        width: 600px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    .title {
        color: #0d6efd;
        font-weight: bold;
    }

    .note {
        font-size: 13px;
        color: #6c757d;
    }

    .eye-btn {
        border: none;
        background: none;
        font-size: 18px;
    }

</style>

<div class="card card-auth p-4">

    <h3 class="text-center mb-4 title">
        Tạo tài khoản nhân viên
    </h3>

    <form asp-controller="Admin" asp-action="CreateNhanVienAccount" method="post" onsubmit="return checkPassword()">
        <div asp-validation-summary="All" class="text-danger"></div>
        <label class="form-label">Tên tài khoản</label>

        <input asp-for="Username"
               class="form-control"
               placeholder="Nhập username">

        <span asp-validation-for="Username" class="text-danger"></span>


        <label class="form-label">Mật khẩu</label>

        <div class="input-group">

                <input asp-for="Password"
                       type="password"
                       id="password"
                       class="form-control"
                       placeholder="Nhập mật khẩu">

                    <span asp-validation-for="Password" class="text-danger"></span>
                    <button type="button" class="eye-btn" onclick="togglePassword()">👁</button>

        </div>

        <div class="note mb-3">
            Mật khẩu phải có ít nhất 6 ký tự
        </div>



     
    

        <button class="btn btn-success w-100 mt-3">
            Tạo tài khoản
        </button>

        <a href="/Admin/NhanVien"
               class="btn btn-secondary w-100 mt-2">
            Quay lại danh sách
        </a>

    </form>

</div>


<script>

    function togglePassword(){

    var x=document.getElementById("password");

    if(x.type==="password"){
    x.type="text";
    }else{
    x.type="password";
    }

    }

    const images=[
    "/images/338596.jpg",
    "/images/1012111.jpg",
    "/images/238870.jpg",
    "/images/37864.jpg",
    "/images/476288.jpg",
    "/images/521718.jpg"
    ];

    const random=Math.floor(Math.random()*images.length);

    document.body.style.backgroundImage="url('"+images[random]+"')";

    function checkPassword(){

    var pass=document.getElementById("password").value;

    if(pass.length<6){
    alert("Mật khẩu phải ít nhất 6 ký tự");
    return false;
    }

    return confirm("Bạn có chắc muốn tạo tài khoản?");
    }

</script>