@model CodeQLTour.Models.NhanVien

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        height: 100vh;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Arial;
    }

    .card-auth {
        width: 720px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    .title {
        color: #0d6efd;
        font-weight: bold;
    }

    .note {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 10px;
    }

    .eye-btn {
        border: none;
        background: none;
        font-size: 18px;
    }

</style>


<div class="card card-auth p-4">

    <h3 class="text-center mb-4 title">
        Chi tiết nhân viên
    </h3>

    <form asp-controller="Admin" asp-action="UpdateNhanVien" method="post" onsubmit="return checkPassword()">

        <input type="hidden" name="MaNV" value="@Model.MaNV" />
        <input type="hidden" name="id" value="@ViewBag.Account?.Id" />

        <div class="row">

            <!-- THÔNG TIN NHÂN VIÊN -->

            <div class="col-md-6">

                <b>Thông tin nhân viên</b>

                <label class="form-label mt-2">Tên nhân viên</label>

                <input class="form-control"
                       name="TenNV"
                       value="@Model.TenNV">

                <label class="form-label mt-3">Chức vụ</label>

                <input class="form-control"
                       name="ChucVu"
                       value="@Model.ChucVu">

                <label class="form-label mt-3">Số điện thoại</label>

                <input class="form-control"
                       name="SoDienThoai"
                       value="@Model.SoDienThoai">

                <div class="note">
                    Ví dụ: 0900000000
                </div>

            </div>


            <!-- THÔNG TIN TÀI KHOẢN -->

            <div class="col-md-6">

                <b>Thông tin tài khoản</b>

                <label class="form-label mt-2">Tài khoản</label>

                <input class="form-control"
                       name="username"
                       value="@ViewBag.Account?.Username">

                <div class="note">
                    Ví dụ: nhập tài khoản
                </div>

                <label class="form-label mt-3">Mật khẩu</label>

                <div class="input-group">

                    <input type="password"
                           id="password"
                           name="password"
                           value="@ViewBag.Account?.Password"
                           class="form-control">

                    <button type="button"
                            class="eye-btn"
                            onclick="togglePassword()">
                        👁
                    </button>

                </div>

                <div class="note">
                    Ví dụ: nhập mật khẩu
                </div>

            </div>

        </div>


        <button class="btn btn-success w-100 mt-4">
            Lưu thay đổi
        </button>

        <a href="/Admin/NhanVien"
               class="btn btn-secondary w-100 mt-2">
            Quay lại danh sách
        </a>

    </form>

</div>


<script>

    function togglePassword(){

    var x=document.getElementById("password");

    if(x.type==="password"){
    x.type="text";
    }else{
    x.type="password";
    }

    }

    const images=[
    "/images/338596.jpg",
    "/images/1012111.jpg",
    "/images/238870.jpg",
    "/images/37864.jpg",
    "/images/476288.jpg",
    "/images/521718.jpg"
    ];

    const random=Math.floor(Math.random()*images.length);

    document.body.style.backgroundImage="url('"+images[random]+"')";

    function checkPassword(){

    var pass=document.getElementById("password").value;

    if(pass.length<6){
    alert("Mật khẩu phải ít nhất 6 ký tự");
    return false;
    }

    return confirm("Bạn có chắc muốn cập nhật thông tin?");
    }

</script>