@model CodeQLTour.Models.KhachHangViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        height: 100vh;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Arial;
    }

    /* CARD */

    .card-auth {
        width: 720px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    /* TITLE */

    .title {
        color: #0d6efd;
        font-weight: bold;
    }

    /* NOTE */

    .note {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 10px;
    }

    /* PASSWORD BUTTON */

    .eye-btn {
        border: none;
        background: none;
        font-size: 18px;
    }

</style>


<div class="card card-auth p-4">

    <h3 class="text-center mb-4 title">
        Chi tiết khách hàng
    </h3>
    <form asp-controller="Admin" asp-action="UpdateKhach" method="post" onsubmit="return checkPassword()">

        <input type="hidden" name="MaKH" value="@Model.MaKH" />
        <input type="hidden" name="id" value="@ViewBag.Account?.Id" />

        <div class="row">

            <!-- THÔNG TIN KHÁCH -->

            <div class="col-md-6">

                <b>Thông tin khách hàng</b>

                <label class="form-label mt-2">Tên khách</label>
                <input class="form-control"
                       name="TenKH"
                       value="@Model.TenKH">

                <label class="form-label mt-3">Ngày sinh</label>
                <input class="form-control"
                       type="date"
                       name="NgaySinh"
                       value="@Model.NgaySinh?.ToString("yyyy-MM-dd")">

                <label class="form-label mt-3">Số điện thoại</label>
                <input class="form-control"
                       name="SoDienThoai"
                       value="@Model.SoDienThoai">

                <div class="note">
                    Ví dụ: 0900000000
                </div>

                <label class="form-label">Email</label>
                <input class="form-control"
                       name="Email"
                       value="@Model.Email">

                <div class="note">
                    Ví dụ email: abc@gmail.com
                </div>

                <label class="form-label">Địa chỉ</label>
                <input class="form-control"
                       name="DiaChi"
                       value="@Model.DiaChi">

                <div class="note">
                    Ví dụ địa chỉ: 12 Nguyễn Văn A, TP.HCM
                </div>

            </div>


            <!-- THÔNG TIN TÀI KHOẢN -->

            <div class="col-md-6">

                <b>Thông tin tài khoản</b>

                <label class="form-label mt-2">Tài khoản</label>
                <input class="form-control"
                       name="username"
                       value="@ViewBag.Account?.Username">

                <div class="note">
                    Ví dụ: nhập tài khoản
                </div>

                <label class="form-label mt-3">Mật khẩu</label>

                <div class="input-group">

                    <input type="password"
                           id="password"
                           name="password"
                           value="@ViewBag.Account?.Password"
                           class="form-control">

                    <button type="button"
                            class="eye-btn"
                            onclick="togglePassword()">
                        👁
                    </button>

                </div>

                <div class="note">
                    Ví dụ: nhập mật khẩu
                </div>

            </div>

        </div>


        <button class="btn btn-success w-100 mt-4">
            Lưu thay đổi
        </button>

        <a asp-action="KhachHang"
               class="btn btn-secondary w-100 mt-2">
            Quay lại danh sách
        </a>

    </form>

</div>


<script>

    function togglePassword(){

    var x=document.getElementById("password");

    if(x.type==="password"){
    x.type="text";
    }else{
    x.type="password";
    }

    }

    const images=[
    "/images/338596.jpg",
    "/images/1012111.jpg",
    "/images/238870.jpg",
    "/images/37864.jpg",
    "/images/476288.jpg",
    "/images/521718.jpg"
    ];

    const random=Math.floor(Math.random()*images.length);

    document.body.style.backgroundImage="url('"+images[random]+"')";

        function checkPassword() {

        var pass = document.getElementById("password").value;

        if (pass.length < 6) {
            alert("Mật khẩu phải có ít nhất 6 ký tự");
            return false;
        }

        return confirm("Bạn có chắc muốn cập nhật thông tin?");
    }

</script>