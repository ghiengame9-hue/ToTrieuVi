@model IEnumerable<CodeQLTour.Models.NhanVienViewModel>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>

    body {
        background: #f4f6f9;
        font-family: Arial;
    }

    /* NAVBAR */

    .navbar {
        background: #0d3b66;
    }

    .navbar-brand {
        font-size: 22px;
    }

    .nav-link {
        color: white !important;
    }

    /* CARD */

    .card-box {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        padding: 20px;
    }

    /* TABLE */

    .table th {
        background: #1d3557;
        color: white;
        text-align: center;
    }

    .table td {
        vertical-align: middle;
    }

    /* BUTTON */

    .btn-warning {
        color: white;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
    }

</style>


<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg">
    <div class="container">

        <a class="navbar-brand text-white fw-bold">
            Tovy Admin
        </a>

        <div class="navbar-nav">

            <a href="/Admin" class="nav-link">
                ⚙ Quay lại Admin
            </a>

        </div>

        <div class="ms-auto d-flex align-items-center">

            <span class="text-white me-3">
                Admin: <b>@Context.Session.GetString("Username")</b>
            </span>

            <a href="/Account/Logout" class="btn btn-danger btn-sm">
                Đăng xuất
            </a>

        </div>

    </div>
</nav>



<!-- CONTENT -->

<div class="container mt-5 pt-4">

    <div class="card-box">

        <div class="d-flex justify-content-between mb-3">

            <div class="page-title">
                Danh sách nhân viên
            </div>

            <a asp-controller="Admin"
                   asp-action="CreateNhanVienAccount"
                   class="btn btn-primary">
                + Thêm nhân viên
            </a>

        </div>


        <table class="table table-bordered table-hover">

            <thead>
                <tr>
                    <th width="60">STT</th>
                    <th>Tài khoản</th>
                    <th>Tên nhân viên</th>
                    <th>Chức vụ</th>
                    <th>Số điện thoại</th>
                    <th width="160">Chức năng</th>
                </tr>
            </thead>

            <tbody>

                @{
                    int stt = 1;
                }

                @foreach (var n in Model)
                {
                    <tr>

                        <td class="text-center">@stt</td>
                        <td>@n.Username</td>
                        <td>@n.TenNV</td>
                        <td>@n.ChucVu</td>
                        <td>@n.SoDienThoai</td>

                        <td class="text-center">

                            <a asp-controller="Admin"
                                   asp-action="EditNhanVien"
                                   asp-route-id="@n.AccountId"
                                   class="btn btn-warning btn-sm">
                                Sửa
                            </a>
                            <form asp-controller="Admin"
                                  asp-action="DeleteNhanVien"
                                  asp-route-id="@n.AccountId"
                                  method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa nhân viên này?');">

                                <button type="submit" class="btn btn-danger btn-sm">
                                    Xóa
                                </button>

                            </form>
                        </td>

                    </tr>

                    stt++;
                }

            </tbody>

        </table>

    </div>

</div>