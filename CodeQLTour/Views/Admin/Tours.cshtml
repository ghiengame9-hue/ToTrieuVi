@model IEnumerable<CodeQLTour.Models.TourDuLich>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>

    body {
        background: #f5f6fa;
    }

    .page-title {
        font-weight: 700;
    }

    .card-box {
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    }

    .table img {
        border-radius: 6px;
    }

    .action-btns a {
        margin-right: 5px;
    }
    .custom-navbar{
    background:#184a78;
    padding:14px 0;
}

.custom-navbar .nav-link{
    margin-right:20px;
    font-size:18px;
}

.admin-link{
    color:#ffc107 !important;
    font-weight:500;
}

.admin-link:hover{
    color:#ffd54f !important;
}

.navbar-brand{
    font-size:22px;
    margin-right:25px;
}
</style>

<nav class="navbar navbar-expand-lg custom-navbar">

    <div class="container">

        <a class="navbar-brand text-white fw-bold">Tovy</a>

        <div class="navbar-nav">

            <a href="/Tour/Index" class="nav-link text-white">
                Trang chủ
            </a>

            <a href="/Admin" class="nav-link admin-link">
                ⚙ Quay lại Admin
            </a>

        </div>

        <div class="ms-auto d-flex align-items-center">

            <span class="text-white me-3">
                Admin: <b>admin</b>
            </span>

            <a href="/Account/Logout" class="btn btn-danger btn-sm">
                Đăng xuất
            </a>

        </div>

    </div>

</nav>
<div class="container mt-4">

    <!-- TIÊU ĐỀ -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="page-title">Quản lý Tour</h3>

    </div>


    <div class="card-box">

        <!-- NÚT THÊM -->
        <div class="mb-3">
            <a href="/Admin/CreateTour" class="btn btn-success">
                + Thêm Tour
            </a>
        </div>


        <table class="table table-hover table-bordered align-middle">

            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên Tour</th>
                    <th>Giá</th>
                    <th>Thời gian</th>
                    <th>Tình trạng</th>
                    <th>Hình</th>
                    <th width="160">Thao tác</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var t in Model)
                {
                    <tr>

                        <td>@t.MaTour</td>

                        <td>
                            <strong>@t.TenTour</strong>
                        </td>

                        <td>
                            @String.Format("{0:N0}", t.GiaVe) VNĐ
                        </td>

                        <td>@t.ThoiGianDi</td>

                        <td>
                            <span class="badge bg-success">
                                @t.TinhTrang
                            </span>
                        </td>

                        <td>
                            <img src="/images/@t.HinhAnh" width="90">
                        </td>

                        <td class="action-btns">

                            <a href="/Admin/EditTour/@t.MaTour" class="btn btn-warning btn-sm">
                                Sửa
                            </a>

                            <form asp-controller="Admin"
                                    asp-action="DeleteTour"
                                  asp-route-id="@t.MaTour"
                                  method="post"
                                  style="display:inline">

                                <button class="btn btn-danger btn-sm"
                                        onclick="return confirm('Bạn có chắc muốn xóa tour này?')">
                                    Xóa
                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
<script>

    let lastScrollTop = 0;
    const navbar = document.querySelector(".navbar");

    window.addEventListener("scroll", function(){

    let scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    if(scrollTop > lastScrollTop){

        // kéo xuống → ẩn
        navbar.style.top = "-80px";

    }else{

        // kéo lên → hiện
        navbar.style.top = "0";

    }

    lastScrollTop = scrollTop;

    });

</script>