@model IEnumerable<dynamic>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>

    body {
        background: #f5f5f5;
        font-family: Segoe UI;
    }

    .checkout-box {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .tour-img {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
    }

    .total {
        font-size: 26px;
        color: #e53935;
        font-weight: bold;
    }

    .buy-btn {
        background: #ee4d2d;
        color: white;
        padding: 12px 40px;
        font-size: 18px;
        border: none;
        border-radius: 6px;
    }

        .buy-btn:hover {
            background: #d73211;
        }
            /* NAVBAR */

    .navbar {
        background: linear-gradient(90deg,#0d3b66,#1c5d99);
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        padding: 16px 0;
    }
    .navbar .nav-link {
        color: white;
        font-weight: 500;
        }

</style>
<nav class="navbar navbar-expand-lg navbar-dark">

    <div class="container">

        <a class="navbar-brand fw-bold">Tovy</a>

        <div class="navbar-nav me-auto">
            <a href="/Tour/Index" class="nav-link text-white">Trang chủ</a>
            <a asp-controller="Cart"
                   asp-action="Index"
                   class="nav-link">
                Giỏ hàng
            </a>
        </div>

        <a asp-controller="KhachHang"
               asp-action="Profile"
               class="btn btn-light me-2">
            Trang cá nhân
        </a>
     
    </div>
</nav>

<form asp-action="DatTour" method="post">

    <div class="container mt-5">

        <!-- THÔNG TIN KHÁCH -->

        <div class="checkout-box mb-4">

            <h5 class="text-danger">📍 Thông Tin Nhận Tour</h5>

            <div class="row mt-3">

                <div class="col-md-4 mb-2">
                    <label>Tên khách hàng</label>
                    <input name="TenKH" class="form-control" value="@ViewBag.TenKH" required>
                </div>

                <div class="col-md-4 mb-2">
                    <label>Số điện thoại</label>
                    <input name="SoDienThoai" class="form-control" value="@ViewBag.SDT" required>
                </div>

                <div class="col-md-4 mb-2">
                    <label>Địa chỉ</label>
                    <input name="DiaChi" class="form-control" value="@ViewBag.DiaChi" required>
                </div>

            </div>
        </div>


        <!-- DANH SÁCH TOUR -->

        <div class="checkout-box">

            <table class="table align-middle">

                <thead class="table-light">

                    <tr>
                        <th>Tour</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Ngày khởi hành</th>
                        <th>Thành tiền</th>
                    </tr>

                </thead>

                <tbody>

                    @{
                        decimal tong = 0;
                    }

                    @foreach (var item in Model)
                    {
                        decimal thanhtien = Convert.ToDecimal(item.GiaVe) * item.SoLuong;
                        tong += thanhtien;

                        <tr>

                            <td>

                                <div class="d-flex gap-3 align-items-center">

                                    <img src="/images/@item.HinhAnh" class="tour-img">

                                    <div>
                                        <strong>@item.TenTour</strong>
                                    </div>

                                </div>

                            </td>

                            <td>
                                @Convert.ToDecimal(item.GiaVe).ToString("N0") đ
                            </td>

                            <td>
                                @item.SoLuong
                            </td>

                            <td>

                                <!-- gửi mã tour -->
                                <input type="hidden" name="MaTour" value="@item.MaTour">

                                <!-- gửi ngày khởi hành -->
                                <input type="hidden" name="NgayKhoiHanh" value="@item.NgayKhoiHanh">

                                @if (item.NgayKhoiHanh == DateTime.MinValue)
                                {
                                    <span class="text-danger">Chưa chọn ngày</span>
                                }
                                else
                                {
                                    <span class="fw-bold">
                                        @item.NgayKhoiHanh.ToString("dd/MM/yyyy")
                                    </span>
                                }

                            </td>

                            <td class="text-danger fw-bold">
                                @thanhtien.ToString("N0") đ
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <hr>


            <!-- GHI CHÚ -->

           


            <!-- TỔNG TIỀN -->

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h5>Tổng thanh toán</h5>

                    <div class="total">
                        @tong.ToString("N0") đ
                    </div>

                </div>

                <button class="btn buy-btn"
                        onclick="return confirm('Bạn có chắc muốn đặt tour không?')">
                    🛒 Đặt Tour
                </button>

            </div>

        </div>

    </div>

</form>