<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>

<body>

    <div class="container mt-3">

        @if (Context.Session.GetString("User") == null)
        {
            <a asp-controller="Account" asp-action="Auth" class="btn btn-outline-dark me-2">
                Đăng nhập
            </a>

            <a asp-controller="Account" asp-action="Auth" class="btn btn-warning">
                Đăng ký
            </a>
        }
        else
        {
            <span class="me-3">
                Xin chào: <b>@Context.Session.GetString("User")</b>
            </span>

            <a asp-controller="KhachHang" asp-action="Profile" class="btn btn-primary me-2">
                Trang cá nhân
            </a>

            <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">
                Đăng xuất
            </a>
        }

    </div>

    <div class="container">
        @RenderBody()
    </div>

</body>
</html>