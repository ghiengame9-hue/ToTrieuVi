@model CodeQLTour.Models.NhanVien

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>

    body {
        background: #eef2f7;
        font-family: 'Segoe UI',sans-serif;
    }

    /* NAVBAR */

    .navbar {
        background: #0d3b66;
    }

    /* HEADER */

    .profile-header {
        background: linear-gradient(120deg,#198754,#20c997);
        padding: 40px;
        color: white;
        border-radius: 15px;
        text-align: center;
        margin-top: 30px;
    }

    .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 4px solid white;
    }

    /* CARD */

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .form-control {
        border-radius: 8px;
    }

    .btn {
        border-radius: 8px;
    }

</style>


<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-dark">

    <div class="container">

        <a class="navbar-brand fw-bold">Tovy</a>

        <div class="navbar-nav me-auto">

            <a href="~/Tour/Index" class="nav-link text-white">
                Trang bán tour
            </a>

        </div>

        <a asp-controller="Account"
               asp-action="Logout"
               class="btn btn-danger">
            Đăng xuất
        </a>

    </div>

</nav>



<div class="container">

    <!-- HEADER -->
    @if (Model != null)
    {
        <div class="profile-header">
            <img src="/images/avatar.png" class="avatar">
            <h4>@Model.TenNV</h4>
            <p>Nhân viên hệ thống Tovy Travel</p>
        </div>

        <!-- phần form giữ nguyên -->
    }
    else
    {
        <div class="alert alert-warning mt-4">
            Chưa có thông tin nhân viên
        </div>
    }


    <div class="row mt-4 g-4">

        <!-- THÔNG TIN NHÂN VIÊN -->

        <div class="col-md-6">

            <form method="post"
                  asp-controller="Staff"
                  asp-action="UpdateProfile">
                <input type="hidden" asp-for="MaNV" />

                <div class="card p-4">

                    <h4 class="mb-3">Thông tin cá nhân</h4>

                    <div class="mb-3">
                        <label class="form-label">Tên nhân viên</label>
                        <input asp-for="TenNV" class="form-control">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ngày sinh</label>
                            <input asp-for="NgaySinh" type="date" class="form-control">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Giới tính</label>
                                <input asp-for="GioiTinh" class="form-control">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Số điện thoại</label>
                                    <input asp-for="SoDienThoai" class="form-control">
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input asp-for="Email" class="form-control">
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Địa chỉ</label>
                                            <input asp-for="DiaChi" class="form-control">
                                            </div>

                                            <button class="btn btn-success w-100">
                                                Cập nhật thông tin
                                            </button>

                                        </div>

                                    </form>

                                </div>



                                <!-- ĐỔI MẬT KHẨU -->

                                <div class="col-md-6">

                                    <form method="post"
                                          asp-controller="Staff"
                                          asp-action="ChangePassword"
                                          onsubmit="return checkPass()">

                                        <div class="card p-4">

                                            <h4 class="mb-3">Đổi mật khẩu</h4>

                                            @if (ViewBag.Error != null)
                                            {
                                                <div class="alert alert-danger">
                                                    @ViewBag.Error
                                                </div>
                                            }

                                            @if (ViewBag.Success != null)
                                            {
                                                <div class="alert alert-success">
                                                    @ViewBag.Success
                                                </div>
                                            }

                                            <div class="mb-3">
                                                <label class="form-label">Mật khẩu cũ</label>
                                                <input type="password" name="OldPassword" class="form-control" required>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label">Mật khẩu mới</label>
                                                <input type="password" name="NewPassword" class="form-control" required>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label">Nhập lại mật khẩu</label>
                                                <input type="password" name="ConfirmPassword" class="form-control" required>
                                            </div>

                                            <button class="btn btn-warning w-100">
                                                Đổi mật khẩu
                                            </button>

                                        </div>

                                    </form>

                                </div>

                            </div>

                        </div>



                        <script>

                            function checkPass(){

                            var newPass=document.querySelector("input[name='NewPassword']").value;

                            var confirm=document.querySelector("input[name='ConfirmPassword']").value;

                            if(newPass.length<6){

                            alert("Mật khẩu phải lớn hơn 6 ký tự");

                            return false;

                            }

                            if(newPass!==confirm){

                            alert("Mật khẩu nhập lại không đúng");

                            return false;

                            }

                            return true;

                            }

                        </script>